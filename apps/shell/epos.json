{
  "$schema": "https://epos.dev/schema.json",
  "name": "[epos]",
  "slug": "epos-shell",
  "version": "1.9",
  "description": "Web Extension Engine.",
  "options": {
    "allowProjectsApi": true,
    "allowMissingModels": true
  },
  "permissions": [
    "background",
    "browsingData",
    "contextMenus",
    "cookies",
    "downloads.ui",
    "downloads",
    "notifications",
    "sidePanel",
    "storage"
  ],
  "hostPermissions": ["<allUrls>"],
  "targets": [
    {
      "matches": ["https://app.epos.dev/*", "https://epos.dev/@learn"],
      "load": ["dist/fonts.css", "dist/gl.css", "dist/gl.js"]
    }
  ],
  "assets": [
    "dist/icon.svg",
    "dist/icon.png",
    "templates/vite/public/epos.svg",
    "templates/vite/src/background.ts",
    "templates/vite/src/main.css",
    "templates/vite/src/main.tsx",
    "templates/vite/.gitignore",
    "templates/vite/epos.json",
    "templates/vite/package.json",
    "templates/vite/tsconfig.json",
    "templates/vite/vite.config.ts"
  ]
}
