{
  "$schema": "https://epos.dev/schema.json",
  "name": "[epos]",
  "slug": "epos-shell",
  "version": "1.8",
  "description": "Web Extension Engine",
  "matches": ["https://app.epos.dev/*", "https://epos.dev/@learn"],
  "load": ["public/jetbrains-mono.css", "dist/gl.css", "dist/gl.js"],
  "assets": ["public/icon.svg", "public/icon.png"],

  "options": {
    "allowProjectsApi": true,
    "allowMissingModels": true
  },

  "hostPermissions": ["<allUrls>"],
  "permissions": [
    "background",
    "browsingData",
    "contextMenus",
    "cookies",
    "downloads",
    "notifications",
    "sidePanel",
    "storage"
  ]
}
