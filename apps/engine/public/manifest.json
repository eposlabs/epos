{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "name": "[epos]",
  "version": "0.0.0",
  "manifest_version": 3,
  "action": { "default_title": "epos" },
  "icons": { "128": "/icon.png" },
  "sandbox": { "pages": ["/project.html"] },
  "background": { "type": "module", "service_worker": "/sw.js" },
  "web_accessible_resources": [{ "matches": ["<all_urls>"], "resources": ["*"] }],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';",
    "sandbox": "sandbox allow-scripts allow-popups allow-modals allow-forms; default-src * blob: data: 'unsafe-eval' 'unsafe-inline';"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["/cs.js"],
      "world": "ISOLATED",
      "run_at": "document_start",
      "all_frames": true,
      "exclude_matches": [
        "https://ogs.google.com/*",
        "https://*.google.com/static/proxy.html?*",
        "https://accounts.google.com/RotateCookiesPage?*"
      ]
    }
  ],

  "host_permissions": ["<all_urls>"],
  "permissions": [
    // Required
    "alarms",
    "declarativeNetRequest",
    "offscreen",
    "unlimitedStorage",

    // Optional
    "background",
    "browsingData",
    "contextMenus",
    "cookies",
    "downloads.ui",
    "downloads",
    "notifications",
    "scripting",
    "sidePanel",
    "storage",
    "tabs",
    "webNavigation"
  ]
}
