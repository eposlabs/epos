{
  "name": "vite-plugin-rebundle",
  "version": "2.0.6",
  "type": "module",
  "license": "MIT",
  "author": "imkost",
  "description": "Vite plugin that forces single-file output per entry. Ensures each entry point is bundled into a standalone file without code-splitting.",
  "keywords": [
    "vite",
    "vite-plugin"
  ],
  "homepage": "https://github.com/eposlabs/epos/tree/main/packages/vite-plugin-rebundle",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eposlabs/epos.git",
    "directory": "packages/vite-plugin-rebundle"
  },
  "scripts": {
    "dev": "rimraf dist && tsgo --watch",
    "build": "rimraf dist && tsgo",
    "lint": "tsgo --build --noEmit"
  },
  "exports": {
    ".": "./dist/rebundle.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@eposlabs/utils": "^1.26.3",
    "@types/ws": "^8.18.1",
    "chalk": "^5.6.2",
    "filesize": "^11.0.15",
    "portfinder": "^1.0.38",
    "rolldown": "^1.0.0-rc.15",
    "vite": "^8.0.8",
    "ws": "^8.20.0"
  }
}
