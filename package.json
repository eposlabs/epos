{
  "name": "eposlabs-epos",
  "version": "*",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "playground/*"
  ],
  "scripts": {
    "edge": "ncu --upgrade --deep && npm install",
    "lint": "npm run lint -w apps -w packages --if-present",
    "prettier": "prettier --write ./",
    "shadcn": "node scripts/shadcn.ts",
    "release": "node scripts/release.ts",
    "reinstall": "npx rimraf --glob node_modules/ package-lock.json **/node_modules/ **/package-lock.json && npm install",
    "docs": "npm run docs:dev",
    "docs:dev": "npm run dev -w docs",
    "docs:build": "npm run build -w docs",
    "docs:preview": "npm run preview -w docs",
    "engine": "npm run engine:dev",
    "engine:dev": "npm run dev -w engine",
    "engine:build": "npm run build -w engine",
    "engine:preview": "npm run preview -w engine",
    "engine:lint": "npm run lint -w engine",
    "shell": "npm run shell:dev",
    "shell:dev": "npm run dev -w shell",
    "shell:build": "npm run build -w shell",
    "shell:lint": "npm run lint -w shell",
    "epos": "npm run epos:dev",
    "epos:dev": "npm run dev -w epos",
    "epos:build": "npm run build -w epos",
    "epos:lint": "npm run lint -w epos",
    "devkit": "npm run devkit:dev",
    "devkit:dev": "npm run dev -w epos-devkit",
    "devkit:build": "npm run build -w epos-devkit",
    "devkit:lint": "npm run lint -w epos-devkit",
    "unit": "npm run unit:dev",
    "unit:dev": "npm run dev -w epos-unit",
    "unit:build": "npm run build -w epos-unit",
    "unit:lint": "npm run lint -w epos-unit",
    "idb": "npm run idb:dev",
    "idb:dev": "npm run dev -w @eposlabs/idb",
    "idb:build": "npm run build -w @eposlabs/idb",
    "idb:lint": "npm run lint -w @eposlabs/idb",
    "types": "npm run types:dev",
    "types:dev": "npm run dev -w @eposlabs/types",
    "types:build": "npm run build -w @eposlabs/types",
    "types:lint": "npm run lint -w @eposlabs/types",
    "utils": "npm run utils:dev",
    "utils:dev": "npm run dev -w @eposlabs/utils",
    "utils:build": "npm run build -w @eposlabs/utils",
    "utils:lint": "npm run lint -w @eposlabs/utils",
    "paralayer": "npm run paralayer:dev",
    "paralayer:dev": "npm run dev -w paralayer",
    "paralayer:build": "npm run build -w paralayer",
    "paralayer:lint": "npm run lint -w paralayer"
  },
  "devDependencies": {
    "@eposlabs/tsconfig": "^1.0.2",
    "@eposlabs/utils": "^1.26.4",
    "npm-check-updates": "^21.0.2",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "syncpack": "^14.3.0"
  }
}
