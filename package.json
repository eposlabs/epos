{
  "name": "monorepo",
  "version": "*",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "playground/*"
  ],
  "scripts": {
    "edge": "ncu --upgrade --deep && npm install",
    "lint": "npm run lint -w apps -w packages",
    "prettier": "prettier --write ./",
    "release": "node scripts/release.ts",
    "reinstall": "npx rimraf node_modules package-lock.json **/node_modules **/package-lock.json && npm install --legacy-peer-deps"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260326.1",
    "npm-check-updates": "^19.6.5",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rimraf": "^6.1.3",
    "syncpack": "^14.2.1"
  }
}
